-- SERVER HOP (différent serveur public)
local function hop()
    local success, result = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(
            "https://games.roblox.com/v1/games/"..PlaceID.."/servers/Public?sortOrder=Desc&limit=100"
        ))
    end)

    if success and result and result.data then
        local found = false

        for _,server in pairs(result.data) do
            if server.id ~= JobID and server.playing < server.maxPlayers then
                TeleportService:TeleportToPlaceInstance(PlaceID, server.id, player)
                found = true
                break
            end
        end

        if not found then
            TeleportService:Teleport(PlaceID, player)
        end
    else
        TeleportService:Teleport(PlaceID, player)
    end
end

-- Lignes
local lines = {}

local function createLines()
    for _,v in pairs(lines) do v:Destroy() end
    lines = {}

    for i=1,5 do
        local players = math.random(6,8) -- minimum 6/8
        local data = getRandom()

        local txt = Instance.new("TextLabel")
        txt.Size = UDim2.new(0.6,0,0,30)
        txt.Position = UDim2.new(0.05,0,0.2 + i*0.11,0)
        txt.BackgroundTransparency = 1
        txt.Text = "👥 "..players.."/8 | "..data[1].." | 💰 "..data[2]
        txt.TextColor3 = Color3.fromRGB(255,255,255)
        txt.TextScaled = true
        txt.Font = Enum.Font.Cartoon
        txt.Parent = frame

        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0.25,0,0,30)
        btn.Position = UDim2.new(0.7,0,0.2 + i*0.11,0)
        btn.Text = "REJOIN"
        btn.BackgroundColor3 = Color3.fromRGB(180,0,0)
        btn.TextScaled = true
        btn.Font = Enum.Font.Cartoon
        btn.Parent = frame

        btn.MouseButton1Click:Connect(hop)

        table.insert(lines, txt)
        table.insert(lines, btn)
    end
end

