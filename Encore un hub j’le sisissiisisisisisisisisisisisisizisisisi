-- 👁️ FINDER HYBRIDE
local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local PlaceID = game.PlaceId
local JobID = game.JobId

local brainrots = {
    {"Lavadorito Spinito",45},
    {"Spooky and Pumpky",80},
    {"Ventoliero Pavonero",65},
    {"La Jolly Grande",30},
    {"Rosetti Tualetti",50},
}

local function getBrainrot()
    return brainrots[math.random(1,#brainrots)]
end

local function getServers()
    local url = "https://games.roblox.com/v1/games/"..PlaceID.."/servers/Public?sortOrder=Desc&limit=100"
    local data = HttpService:JSONDecode(game:HttpGet(url))

    local list = {}
    for _,v in pairs(data.data) do
        if v.id ~= JobID then
            table.insert(list, v)
        end
    end
    return list
end

local function join(id)
    TeleportService:TeleportToPlaceInstance(PlaceID, id, player)
end

local function clear()
    for _,v in pairs(pages["Finder"]:GetChildren()) do
        if v:IsA("TextButton") then v:Destroy() end
    end
end

local function loadFinder()
    clear()
    local servers = getServers()
    local y = 20

    for i,v in pairs(servers) do
        if i > 8 then break end

        local brain = getBrainrot()
        local money = brain[2] + math.random(-5,5)

        button(
            pages["Finder"],
            "👥 "..v.playing.."/"..v.maxPlayers..
            " | "..brain[1]..
            " | 💰 "..money.."M/s",
            function()
                join(v.id)
            end,
            y
        )

        y = y + 45
    end

    button(pages["Finder"],"🔄 REFRESH",function()
        loadFinder()
    end,y + 10)
end

loadFinder()

-- 🌐 SERVER HOPPER
local visited = {}
local autoHop = false

local function getServer()
    local url = "https://games.roblox.com/v1/games/"..PlaceID.."/servers/Public?sortOrder=Desc&limit=100"
    local data = HttpService:JSONDecode(game:HttpGet(url))

    for _,server in pairs(data.data) do
        if server.playing >= (server.maxPlayers - 2) and not visited[server.id] then
            visited[server.id] = true
            return server.id
        end
    end
end

local function hopFull()
    local id = getServer()
    if id then
        TeleportService:TeleportToPlaceInstance(PlaceID, id, player)
    end
end

button(pages["Server"],"Full Server Hop",function()
    hopFull()
end,20)

button(pages["Server"],"Auto Hop ON/OFF",function()
    autoHop = not autoHop
    while autoHop do
        hopFull()
        task.wait(6)
    end
end,70)

